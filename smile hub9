-- [[ 土星実行ループ：修正版 ]]
task.spawn(function()
    local c = { Speed = 2, Size = 12, Height = 5, WaveSpeed = 2, WaveAmp = 2 }
    local shape = {}
    for i = 1, 36 do
        local angle = math.rad(i * 10)
        table.insert(shape, Vector3.new(math.cos(angle), 0, math.sin(angle)))
    end

    while true do
        task.wait() -- ループを常に回し、中でEnabledをチェックする
        if SaturnEnabled then
            local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local time = tick()
                local wingItems = {}
                
                -- アイテムスキャン
                local allPossibleFolders = {
                    workspace:FindFirstChild(myName .. "SpawnedInToys"),
                    workspace:FindFirstChild("PlotItems") -- プロット内のフォルダは後で中身を精査
                }

                for _, folder in ipairs(allPossibleFolders) do
                    if folder then
                        -- PlotItemsの場合は自分のプロットフォルダを探す
                        if folder.Name == "PlotItems" then
                            local plots = workspace:FindFirstChild("Plots")
                            if plots then
                                for _, plot in ipairs(plots:GetChildren()) do
                                    local sign = plot:FindFirstChild("PlotSign")
                                    local owner = sign and (sign:FindFirstChild("ThisPlotsOwners") or sign:FindFirstChild("Owner"))
                                    local val = owner and (owner:FindFirstChild("Value") or owner)
                                    local data = val and (val:FindFirstChild("Data") or val)
                                    
                                    if data and data:IsA("StringValue") and data.Value == myName then
                                        local myPlotFolder = folder:FindFirstChild(plot.Name)
                                        if myPlotFolder then
                                            for _, item in ipairs(myPlotFolder:GetChildren()) do
                                                -- 名前に「Wing」か「羽」があるか厳格にチェック
                                                local n = item.Name:lower()
                                                if (n:find("wing") or n:find("羽")) and item:IsA("Model") and item.PrimaryPart then
                                                    table.insert(wingItems, item)
                                                end
                                            end
                                        end
                                    end
                                end
                            end
                        else
                            -- SpawnedInToysの場合
                            for _, item in ipairs(folder:GetChildren()) do
                                local n = item.Name:lower()
                                if (n:find("wing") or n:find("羽")) and item:IsA("Model") and item.PrimaryPart then
                                    table.insert(wingItems, item)
                                end
                            end
                        end
                    end
                end

                -- 軌道計算
                local total = #wingItems
                for i, item in ipairs(wingItems) do
                    pcall(function()
                        item.PrimaryPart.CanCollide = false
                        item.PrimaryPart.SetNetworkOwner(item.PrimaryPart, LP)
                        
                        local pos = Vector3.zero
                        if i % 2 == 0 then
                            local phi = math.acos(-1 + (2 * i) / total)
                            local theta = math.sqrt(total * math.pi) * phi + time * c.Speed
                            pos = Vector3.new(c.Size * math.cos(theta) * math.sin(phi), c.Size * math.sin(theta) * math.sin(phi) + c.Height, c.Size * math.cos(phi))
                        else
                            local cycle = (time * c.Speed * 0.1 + (i/total)) % 1
                            local step = cycle * #shape
                            local p = shape[math.floor(step)%#shape+1]:Lerp(shape[math.floor(step+1)%#shape+1], step%1)
                            local rot = time * c.Speed * 0.3
                            pos = Vector3.new((p.X*math.cos(rot)-p.Z*math.sin(rot))*c.Size, c.Height+(math.sin(time*c.WaveSpeed+i*0.5)*c.WaveAmp), (p.X*math.sin(rot)+p.Z*math.cos(rot))*c.Size)
                        end
                        item:SetPrimaryPartCFrame(hrp.CFrame * CFrame.new(pos))
                    end)
                end
            end
        else
            -- [[ 重要：オフにした時の解放処理 ]]
            -- 必要に応じて、一旦掴んでいたアイテムの物理を安定させる
        end
    end
