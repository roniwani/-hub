-- 1. LOOP KILL
LoopTab:AddToggle({
    Name = "ループ・キル (Kill Selected)",
    Default = false,
    Callback = function(v)
        isLoopKilling = v
        if v then
            task.spawn(function()
                while isLoopKilling do
                    for i = #selectedLoopPlayers, 1, -1 do
                        if not isLoopKilling then break end
                        local target = game.Players:FindFirstChild(selectedLoopPlayers[i])
                        if target and target.Character then
                            local root = target.Character:FindFirstChild("HumanoidRootPart")
                            local hum = target.Character:FindFirstChildOfClass("Humanoid")
                            if root and hum and hum.Health > 0 then
                                EnableNoclip()
                                SNOWship(root)
                                if CheckNetworkOwnership(target) then
                                    CreateSkyVelocity(root)
                                    local ev = game:GetService("ReplicatedStorage"):FindFirstChild("GrabEvents")
                                    if ev then ev.DestroyGrabLine:FireServer(root) end
                                end
                                hum:ChangeState(Enum.HumanoidStateType.Dead)
                            end
                        end
                    end
                    task.wait(0.2)
                end
                DisableNoclip()
            end)
        end
    end
})

