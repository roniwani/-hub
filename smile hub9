})

-- 制御変数（Blitzロジック用）
local selectedLoopPlayers = {}
local isLoopKilling = false
local isLoopBringing = false
local isLoopKicking = false
local Noclipping = false
local NoclipConnection = nil

-- --- Blitz内部関数 (物理・ネットワーク制御) ---

local function lookAt(from, to)
    local direction = (to - from).Unit
    local right = direction:Cross(Vector3.new(0, 1, 0))
    local up = right:Cross(direction)
    return CFrame.fromMatrix(from, right, up)
end

local function EnableNoclip()
    if not NoclipConnection then
        Noclipping = false
        NoclipConnection = game:GetService("RunService").Stepped:Connect(function()
            if Noclipping == false and LP.Character then
                for _, part in pairs(LP.Character:GetChildren()) do
                    if part:IsA("BasePart") and part.CanCollide and part.Name ~= "floatName" then
                        part.CanCollide = false
                    end
                end
            end
        end)
    end
end

local function DisableNoclip()
    if NoclipConnection then
        NoclipConnection:Disconnect()
        NoclipConnection = nil
    end
    Noclipping = true
end

local function SNOWship(part)
    local GrabEvents = game:GetService("ReplicatedStorage"):WaitForChild("GrabEvents", 3)
    if not GrabEvents then return end
    local SetNetworkOwner = GrabEvents:WaitForChild("SetNetworkOwner", 3)
    
    if part and typeof(part) == "Instance" and SetNetworkOwner then
        local distance = LP:DistanceFromCharacter(part.Position)
        if LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") and distance <= 30 then
            SetNetworkOwner:FireServer(part, lookAt(LP.Character.HumanoidRootPart.Position, part.Position))
        end
    end
end

local function CreateSkyVelocity(part)
    if not part:FindFirstChild("SkyVelocity") then
        local bv = Instance.new("BodyVelocity", part)
        bv.Name = "SkyVelocity"
        bv.Velocity = Vector3.new(0, 100000000000000, 0)
        bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    end
end

local function CheckNetworkOwnership(player)
    if player and player.Character then
        local head = player.Character:FindFirstChild("Head")
        if head and head:FindFirstChild("PartOwner") and head.PartOwner.Value == LP.Name then
            return true
        end
    end
    return false
end

-- --- ターゲット管理セクション ---
LoopTab:AddSection({ Name = "ターゲット管理" })

local LoopPlayerDropdown
local SelectedLabel = LoopTab:AddLabel("Selected: None")

local function UpdateSelectedList()
    if #selectedLoopPlayers == 0 then
        SelectedLabel:Set("Selected: None")
    else
        SelectedLabel:Set("Selected: " .. table.concat(selectedLoopPlayers, ", "))
    end
end

local function UpdateLoopPlayerList()
    local options = {}
    for _, player in pairs(game.Players:GetPlayers()) do
        if player ~= LP and not table.find(selectedLoopPlayers, player.Name) then
            table.insert(options, player.Name .. " (" .. player.DisplayName .. ")")
        end
    end
    table.sort(options)
    if LoopPlayerDropdown then LoopPlayerDropdown:Refresh(options, true) end
end

LoopPlayerDropdown = LoopTab:AddDropdown({
    Name = "ターゲットを選択して追加",
    Options = {},
    Callback = function(value)
        local playerName = string.split(value, " ")[1]
        if not table.find(selectedLoopPlayers, playerName) then
            table.insert(selectedLoopPlayers, playerName)
            UpdateSelectedList()
            UpdateLoopPlayerList()
        end
    end
})

LoopTab:AddButton({
    Name = "選択をリセット",
    Callback = function()
        selectedLoopPlayers = {}
        UpdateSelectedList()
        UpdateLoopPlayerList()
    end
})

