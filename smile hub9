-- --- ユーティリティ関数 ---
local function findMyBlobman()
    for _, v in ipairs(workspace:GetDescendants()) do
        if v.Name == "CreatureBlobman" and v:FindFirstChild("VehicleSeat") then
            local weld = v.VehicleSeat:FindFirstChild("SeatWeld")
            if weld and weld.Part1 and weld.Part1:IsDescendantOf(LP.Character) then
                return v
            end
        end
    end
    return nil
end

local function blobGrabPlayer(player, blobman, side)
    local targetHRP = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not targetHRP then return end
    local detector = (side == "Left") and blobman:FindFirstChild("LeftDetector") or blobman:FindFirstChild("RightDetector")
    local weld = detector and detector:FindFirstChild(side .. "Weld")
    local remote = blobman:FindFirstChild("BlobmanSeatAndOwnerScript") and blobman.BlobmanSeatAndOwnerScript:FindFirstChild("CreatureGrab")
    if detector and weld and remote then
        pcall(function() remote:FireServer(detector, targetHRP, weld) end)
    end
end

-- アンカー処理
local function AnchorBlob(blob)
    if not blob then return end
    for _, part in ipairs(blob:GetDescendants()) do
        if part:IsA("BasePart") then part.Anchored = true end
    end
end

local function UnanchorBlob(blob)
    if not blob then return end
    for _, part in ipairs(blob:GetDescendants()) do
        if part:IsA("BasePart") then part.Anchored = false end
    end
end

